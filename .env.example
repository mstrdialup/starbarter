# SpaceTraders API token (required)
ST_TOKEN=your_token_here

# Path to SQLite database (overridden by docker-compose to /data/spacetraders.db)
# ST_DB_PATH=~/.local/share/spacetraders/spacetraders.db

# SpaceTraders API base URL
# ST_BASE_URL=https://api.spacetraders.io/v2

# Web server port (also controls host-side port mapping in docker-compose)
ST_WEB_PORT=8080

# CORS allowed origins (comma-separated, default *)
# ST_ALLOWED_ORIGINS=http://localhost:8080,https://yourdomain.com
